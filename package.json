{
  "name": "mtg-collector",
  "version": "1.0.0",
  "description": "Build script for static dist output.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync:styles:dist": "sass --style=compressed --load-path=node_modules --silence-deprecation=if-function src/ui/styles.scss dist/assets/styles.min.css --no-source-map",
    "bundle:js:dist": "esbuild src/main.ts --bundle --minify --format=esm --target=es2019 --outfile=dist/assets/app.min.js",
    "optimize:dist": "node scripts/optimize-dist.js",
    "build": "node scripts/build.js && npm run sync:styles:dist && npm run bundle:js:dist && npm run optimize:dist",
    "dev": "npm run build && npx serve dist",
    "watch": "sass --watch --load-path=node_modules --silence-deprecation=if-function src/ui/styles.scss dist/assets/styles.min.css --no-source-map",
    "serve": "npx serve dist",
    "lint": "eslint . && stylelint 'src/**/*.scss' --fix",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@carbon/styles": "1.109.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@typescript-eslint/parser": "^8.62.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.6.0",
    "html-minifier-terser": "^7.2.0",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}

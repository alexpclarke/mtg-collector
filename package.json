{
  "name": "mtg-collector",
  "version": "1.0.0",
  "description": "MTG collection box packer — CSV + Scryfall in the browser.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync:data": "node scripts/build.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . && stylelint 'src/**/*.scss' --fix",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@carbon/styles": "1.109.0",
    "@carbon/vue": "^3.0.30",
    "papaparse": "5.5.3",
    "vue": "3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/papaparse": "5.5.2",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-vue": "5.2.4",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "8.1.3"
  }
